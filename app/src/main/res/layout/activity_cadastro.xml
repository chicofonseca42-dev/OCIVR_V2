<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F172A"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- LOGOS -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_alignParentStart="true">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="OCI"
                android:textSize="32sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:letterSpacing="0.05"
                android:fontFamily="sans-serif-condensed"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="VR"
                android:textSize="32sp"
                android:textStyle="bold"
                android:textColor="#4DD0E1"
                android:letterSpacing="0.05"
                android:fontFamily="sans-serif-condensed"/>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MEO"
            android:textSize="40sp"
            android:textStyle="bold"
            android:textColor="#B0BEC5"
            android:letterSpacing="0.08"
            android:fontFamily="@font/exo2_bold"
            android:layout_alignParentEnd="true"/>
    </RelativeLayout>

    <!-- REDE 54 -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/rede54"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"
        android:clickable="true"
        android:focusable="true"
        app:rippleColor="#33FFFFFF"
        app:cardCornerRadius="16dp"
        app:cardBackgroundColor="#12FFFFFF"
        app:cardElevation="0dp"
        app:strokeColor="#4DD0E1"
        app:strokeWidth="1.5dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingVertical="16dp"
            android:paddingHorizontal="16dp"
            android:gravity="center_vertical">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Rede 54"
                android:textSize="15sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:gravity="center"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="›"
                android:textSize="22sp"
                android:textColor="#44FFFFFF"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- REDE 59 -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/rede59"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"
        android:clickable="true"
        android:focusable="true"
        app:rippleColor="#33FFFFFF"
        app:cardCornerRadius="16dp"
        app:cardBackgroundColor="#12FFFFFF"
        app:cardElevation="0dp"
        app:strokeColor="#4DD0E1"
        app:strokeWidth="1.5dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingVertical="16dp"
            android:paddingHorizontal="16dp"
            android:gravity="center_vertical">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Rede 59"
                android:textSize="15sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:gravity="center"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="›"
                android:textSize="22sp"
                android:textColor="#44FFFFFF"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- REDE 76 -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/rede76"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"
        android:clickable="true"
        android:focusable="true"
        app:rippleColor="#33FFFFFF"
        app:cardCornerRadius="16dp"
        app:cardBackgroundColor="#12FFFFFF"
        app:cardElevation="0dp"
        app:strokeColor="#4DD0E1"
        app:strokeWidth="1.5dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingVertical="16dp"
            android:paddingHorizontal="16dp"
            android:gravity="center_vertical">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Rede 76"
                android:textSize="15sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:gravity="center"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="›"
                android:textSize="22sp"
                android:textColor="#44FFFFFF"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- OLT'S -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/olts"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"
        android:clickable="true"
        android:focusable="true"
        app:rippleColor="#33FFFFFF"
        app:cardCornerRadius="16dp"
        app:cardBackgroundColor="#12FFFFFF"
        app:cardElevation="0dp"
        app:strokeColor="#4DD0E1"
        app:strokeWidth="1.5dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingVertical="16dp"
            android:paddingHorizontal="16dp"
            android:gravity="center_vertical">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="OLT's"
                android:textSize="15sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:gravity="center"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="›"
                android:textSize="22sp"
                android:textColor="#44FFFFFF"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>