<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F172A">

    <!-- ═══════════════════════════════════════ -->
    <!-- LOGO OCIVR                             -->
    <!-- ═══════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_margin="24dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="OCI"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:letterSpacing="0.05"
            android:fontFamily="sans-serif-condensed"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="VR"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="#4DD0E1"
            android:letterSpacing="0.05"
            android:fontFamily="sans-serif-condensed"/>

    </LinearLayout>

    <!-- ═══════════════════════════════════════ -->
    <!-- LOGO MEO                               -->
    <!-- ═══════════════════════════════════════ -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="MEO"
        android:textSize="40sp"
        android:textStyle="bold"
        android:textColor="#B0BEC5"
        android:letterSpacing="0.08"
        android:fontFamily="@font/exo2_bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="50dp"
        android:layout_marginEnd="40dp"/>

    <!-- ========================= -->
    <!--       BLOCO REDE 54       -->
    <!-- ========================= -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/rede54"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="10dp"
        android:clickable="true"
        android:focusable="true"
        app:rippleColor="#33FFFFFF"
        app:cardCornerRadius="16dp"
        app:cardBackgroundColor="#12FFFFFF"
        app:cardElevation="0dp"
        android:elevation="0dp"
        app:strokeColor="#4DD0E1"
        app:strokeWidth="1.5dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/rede59"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingVertical="16dp"
            android:paddingHorizontal="16dp"
            android:gravity="center_vertical">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Rede 54"
                android:textSize="15sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:gravity="center"
                android:textAlignment="center"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="›"
                android:textSize="22sp"
                android:textColor="#44FFFFFF"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- ========================= -->
    <!--       BLOCO REDE 59       -->
    <!-- ========================= -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/rede59"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="10dp"
        android:clickable="true"
        android:focusable="true"
        app:rippleColor="#33FFFFFF"
        app:cardCornerRadius="16dp"
        app:cardBackgroundColor="#12FFFFFF"
        app:cardElevation="0dp"
        android:elevation="0dp"
        app:strokeColor="#4DD0E1"
        app:strokeWidth="1.5dp"
        app:layout_constraintTop_toBottomOf="@id/rede54"
        app:layout_constraintBottom_toTopOf="@id/rede76"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingVertical="16dp"
            android:paddingHorizontal="16dp"
            android:gravity="center_vertical">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Rede 59"
                android:textSize="15sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:gravity="center"
                android:textAlignment="center"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="›"
                android:textSize="22sp"
                android:textColor="#44FFFFFF"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- ========================= -->
    <!--       BLOCO REDE 76       -->
    <!-- ========================= -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/rede76"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="10dp"
        android:clickable="true"
        android:focusable="true"
        app:rippleColor="#33FFFFFF"
        app:cardCornerRadius="16dp"
        app:cardBackgroundColor="#12FFFFFF"
        app:cardElevation="0dp"
        android:elevation="0dp"
        app:strokeColor="#4DD0E1"
        app:strokeWidth="1.5dp"
        app:layout_constraintTop_toBottomOf="@id/rede59"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingVertical="16dp"
            android:paddingHorizontal="16dp"
            android:gravity="center_vertical">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Rede 76"
                android:textSize="15sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:gravity="center"
                android:textAlignment="center"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="›"
                android:textSize="22sp"
                android:textColor="#44FFFFFF"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>