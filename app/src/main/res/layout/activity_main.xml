<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- FUNDO -->
    <View
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#0F172A"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ═══════════════════════════════════════ -->
    <!-- LOGO OCIVR                             -->
    <!-- ═══════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_margin="24dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="OCI"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:letterSpacing="0.05"
            android:fontFamily="sans-serif-condensed"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="VR"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="#4DD0E1"
            android:letterSpacing="0.05"
            android:fontFamily="sans-serif-condensed"/>

    </LinearLayout>

    <!-- SCROLL PRINCIPAL -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="120dp"
            android:paddingBottom="30dp">

            <!-- CARD Semana Atual -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardSemanaAtual"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="10dp"
                android:clickable="true"
                android:focusable="true"
                app:rippleColor="#33FFFFFF"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="#12FFFFFF"
                app:cardElevation="0dp"
                android:elevation="0dp"
                app:strokeColor="#4DD0E1"
                app:strokeWidth="1.5dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp"
                    android:gravity="center_vertical">

                    <androidx.cardview.widget.CardView
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        app:cardCornerRadius="12dp"
                        app:cardBackgroundColor="#2828A0CC"
                        app:cardElevation="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/txtMesIcone"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="JAN"
                                android:textSize="8sp"
                                android:textColor="#4DD0E1"
                                android:textStyle="bold"
                                android:letterSpacing="0.1"/>

                            <TextView
                                android:id="@+id/txtDiaIcone"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="01"
                                android:textSize="16sp"
                                android:textColor="#FFFFFF"
                                android:textStyle="bold"/>

                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingStart="14dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Semana Atual"
                            android:textSize="14sp"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:textSize="22sp"
                        android:textColor="#44FFFFFF"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- CARD Todos os Sites -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardTodosSites"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="10dp"
                android:clickable="true"
                android:focusable="true"
                app:rippleColor="#33FFFFFF"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="#12FFFFFF"
                app:cardElevation="0dp"
                android:elevation="0dp"
                app:strokeColor="#4DD0E1"
                app:strokeWidth="1.5dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp"
                    android:gravity="center_vertical">
                    <androidx.cardview.widget.CardView
                        android:layout_width="42dp" android:layout_height="42dp"
                        app:cardCornerRadius="12dp" app:cardBackgroundColor="#2828A0CC" app:cardElevation="0dp">
                        <TextView android:layout_width="match_parent" android:layout_height="match_parent" android:text="🌐" android:textSize="16sp" android:gravity="center"/>
                    </androidx.cardview.widget.CardView>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:paddingStart="14dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Todos os Sites" android:textSize="14sp" android:textColor="#FFFFFF" android:textStyle="bold"/>
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="›" android:textSize="22sp" android:textColor="#44FFFFFF"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- GRELHA 2x3: Ferramentas -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="10dp"
                android:columnCount="2"
                android:rowCount="3"
                android:useDefaultMargins="false">

                <!-- Cadastro -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardCadastro"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_columnWeight="1" android:layout_margin="5dp"
                    android:clickable="true" android:focusable="true"
                    app:rippleColor="#33FFFFFF"
                    app:cardCornerRadius="16dp" app:cardBackgroundColor="#12FFFFFF"
                    app:cardElevation="0dp" app:strokeColor="#4DD0E1" app:strokeWidth="1.5dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="18dp" android:gravity="center">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="📋" android:textSize="16sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="CADASTRO" android:textSize="11sp" android:textColor="#FFFFFF" android:textStyle="bold" android:layout_marginTop="8dp" android:letterSpacing="0.1"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Prevenção -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardPrevencao"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_columnWeight="1" android:layout_margin="5dp"
                    android:clickable="true" android:focusable="true"
                    app:rippleColor="#33FFFFFF"
                    app:cardCornerRadius="16dp" app:cardBackgroundColor="#12FFFFFF"
                    app:cardElevation="0dp" app:strokeColor="#4DD0E1" app:strokeWidth="1.5dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="18dp" android:gravity="center">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🛡️" android:textSize="16sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="PREVENÇÃO" android:textSize="11sp" android:textColor="#FFFFFF" android:textStyle="bold" android:layout_marginTop="8dp" android:letterSpacing="0.1"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- CPL Web -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardCplWeb"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_columnWeight="1" android:layout_margin="5dp"
                    android:clickable="true" android:focusable="true"
                    app:rippleColor="#33FFFFFF"
                    app:cardCornerRadius="16dp" app:cardBackgroundColor="#12FFFFFF"
                    app:cardElevation="0dp" app:strokeColor="#4DD0E1" app:strokeWidth="1.5dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="18dp" android:gravity="center">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="💻" android:textSize="16sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="CPL WEB" android:textSize="11sp" android:textColor="#FFFFFF" android:textStyle="bold" android:layout_marginTop="8dp" android:letterSpacing="0.1"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- RETA/SGA -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardRetaSga"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_columnWeight="1" android:layout_margin="5dp"
                    android:clickable="true" android:focusable="true"
                    app:rippleColor="#33FFFFFF"
                    app:cardCornerRadius="16dp" app:cardBackgroundColor="#12FFFFFF"
                    app:cardElevation="0dp" app:strokeColor="#4DD0E1" app:strokeWidth="1.5dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="18dp" android:gravity="center">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="📡" android:textSize="16sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="RETA/SGA" android:textSize="11sp" android:textColor="#FFFFFF" android:textStyle="bold" android:layout_marginTop="8dp" android:letterSpacing="0.1"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- SOUMEO -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardSouMeo"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_columnWeight="1" android:layout_margin="5dp"
                    android:clickable="true" android:focusable="true"
                    app:rippleColor="#33FFFFFF"
                    app:cardCornerRadius="16dp" app:cardBackgroundColor="#12FFFFFF"
                    app:cardElevation="0dp" app:strokeColor="#4DD0E1" app:strokeWidth="1.5dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="18dp" android:gravity="center">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="📱" android:textSize="16sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="SOUMEO" android:textSize="11sp" android:textColor="#FFFFFF" android:textStyle="bold" android:layout_marginTop="8dp" android:letterSpacing="0.1"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Circuitos -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardCircuitos"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_columnWeight="1" android:layout_margin="5dp"
                    android:clickable="true" android:focusable="true"
                    app:rippleColor="#33FFFFFF"
                    app:cardCornerRadius="16dp" app:cardBackgroundColor="#12FFFFFF"
                    app:cardElevation="0dp" app:strokeColor="#4DD0E1" app:strokeWidth="1.5dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="18dp" android:gravity="center">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🔗" android:textSize="16sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="CIRCUITOS" android:textSize="11sp" android:textColor="#FFFFFF" android:textStyle="bold" android:layout_marginTop="8dp" android:letterSpacing="0.1"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </GridLayout>

            <!-- CARD Agendamentos -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardAgendamentos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="10dp"
                android:clickable="true"
                android:focusable="true"
                app:rippleColor="#33FFFFFF"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="#12FFFFFF"
                app:cardElevation="0dp"
                android:elevation="0dp"
                app:strokeColor="#4DD0E1"
                app:strokeWidth="1.5dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp"
                    android:gravity="center_vertical">
                    <androidx.cardview.widget.CardView
                        android:layout_width="42dp" android:layout_height="42dp"
                        app:cardCornerRadius="12dp" app:cardBackgroundColor="#2828A0CC" app:cardElevation="0dp">
                        <TextView android:layout_width="match_parent" android:layout_height="match_parent" android:text="📈" android:textSize="16sp" android:gravity="center"/>
                    </androidx.cardview.widget.CardView>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:paddingStart="14dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Agendamentos" android:textSize="14sp" android:textColor="#FFFFFF" android:textStyle="bold"/>
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="›" android:textSize="22sp" android:textColor="#44FFFFFF"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

    <!-- BOTÃO ⚙️ CONFIGURAÇÕES -->
    <ImageButton
        android:id="@+id/btnConfiguracoes"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_margin="16dp"
        android:src="@drawable/ic_settings"
        android:background="@drawable/bg_icon"
        android:contentDescription="@string/configuracoes"
        android:scaleType="center"
        android:padding="12dp"
        android:clipToOutline="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>