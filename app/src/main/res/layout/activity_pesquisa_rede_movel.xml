<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F172A">





    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:padding="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- INPUT -->
        <EditText
            android:id="@+id/etPesquisa"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="@string/hint_rede_movel"
            android:inputType="text"
            android:imeOptions="actionSearch"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:textColorHint="#88FFFFFF"
            android:background="@drawable/bg_input_ocivr"
            android:padding="14dp"
            android:layout_marginBottom="16dp"/>

        <!-- BOTÃO PESQUISAR -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnPesquisar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clickable="true"
            android:focusable="true"
            app:rippleColor="#33FFFFFF"
            app:cardCornerRadius="20dp"
            app:cardBackgroundColor="#12FFFFFF"
            app:cardElevation="0dp"
            app:strokeColor="#4DD0E1"
            app:strokeWidth="1.5dp"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="20dp"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/pesquisar"
                    android:textSize="16sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"/>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- RESULTADOS -->
        <ScrollView
            android:id="@+id/scrollResultados"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <LinearLayout
                android:id="@+id/containerResultados"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"/>
        </ScrollView>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
